{
  "name": "opencode-provider-proxy",
  "version": "1.0.0",
  "description": "Route OpenCode AI provider requests through per-host proxies (SOCKS / HTTP CONNECT)",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "README_ZH.md"
  ],
  "scripts": {
    "bundle": "esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --external:@opencode-ai/plugin",
    "prepublishOnly": "npm run bundle"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "proxy",
    "socks5",
    "http-proxy",
    "github-copilot"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmNaN/opencode-provider-proxy.git"
  },
  "homepage": "https://github.com/cmNaN/opencode-provider-proxy#readme",
  "bugs": {
    "url": "https://github.com/cmNaN/opencode-provider-proxy/issues"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.9",
    "@types/node": "^22.20.0",
    "esbuild": "^0.28.1",
    "netbun": "^0.3.0",
    "typescript": "^5.9.3"
  }
}
